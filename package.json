{
  "name": "work-notes-reporter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first TypeScript CLI for daily/weekly/monthly work summaries.",
  "bin": {
    "worklog": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
